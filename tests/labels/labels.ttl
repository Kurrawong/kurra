PREFIX dcterms: <http://purl.org/dc/terms/>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX prez: <https://prez.dev/>
PREFIX prof: <http://www.w3.org/ns/dx/prof/>
PREFIX schema: <https://schema.org/>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

<http://purl.org/NET/rdflicense/cc-by4.0>
    schema:name "Creative Commons CC-BY" ;
    schema:url "http://creativecommons.org/licenses/by/4.0/legalcode"^^xsd:anyURI ;
.

dcterms:conformsTo
    schema:description "An established standard to which the described resource conforms." ;
    schema:name "Conforms To" ;
.

owl:versionIRI
    schema:description "The property that identifies the version IRI of an ontology." ;
    schema:name "versionIRI" ;
.

skos:Concept
    schema:description "An idea or notion; a unit of thought." ;
    schema:name "Concept" ;
.

skos:ConceptScheme
    schema:description "A set of concepts, optionally including statements about semantic relationships between those concepts." ;
    schema:name "Concept Scheme" ;
.

skos:altLabel
    schema:description "An alternative lexical label for a resource." ;
    schema:name "alternative label" ;
.

skos:broader
    schema:description "Relates a concept to a concept that is more general in meaning." ;
    schema:name "has broader" ;
.

skos:definition
    schema:description "A statement or formal explanation of the meaning of a concept." ;
    schema:name "definition" ;
.

skos:hasTopConcept
    schema:description "Relates, by convention, a concept scheme to a concept which is topmost in the broader/narrower concept hierarchies for that scheme, providing an entry point to these hierarchies." ;
    schema:name "has top concept" ;
.

skos:historyNote
    schema:description "A note about the past state/use/meaning of a concept." ;
    schema:name "history note" ;
.

skos:inScheme
    schema:description "Relates a resource (for example a concept) to a concept scheme in which it is included." ;
    schema:name "is in scheme" ;
.

skos:narrower
    schema:description "Relates a concept to a concept that is more specific in meaning." ;
    schema:name "has narrower" ;
.

skos:prefLabel
    schema:description "The preferred lexical label for a resource, in a given language." ;
    schema:name "preferred label" ;
.

skos:topConceptOf
    schema:description "Relates a concept to the concept scheme that it is a top level concept of." ;
    schema:name "is top concept in scheme" ;
.

prof:hasArtifact
    schema:description "The URL of a downloadable file with particulars such as its format and role indicated by the Resource Descriptor" ;
    schema:name "has artifact" ;
.

prof:hasResource
    schema:description "A resource which describes the nature of an artifact and the role it plays in relation to the Profile" ;
    schema:name "has resource" ;
.

prof:hasRole
    schema:description "The function of an artifact described by a Resource Descriptor, such as specification, guidance etc." ;
    schema:name "has role" ;
.

<https://kurrawong.ai>
    schema:name "KurrawongAI" ;
.

<https://linked.data.gov.au/def/bcp/validator>
    schema:description "The Basic Catalogue Profile validator" ;
    schema:name "Basic Catalogue Profile Validator" ;
.

<https://linked.data.gov.au/def/data-roles/custodian>
    schema:description "party that accepts accountability and responsibility for the resource and ensures appropriate care and maintenance of the resource" ;
    schema:name "custodian"@en ;
.

<https://linked.data.gov.au/def/vocpub/validator>
    schema:description "SHACL validator for the VocPub Profile" ;
    schema:name "VocPub Validator" ;
.

prez:Manifest
    schema:description "An RDF file that describes and links to a set of resources that can be loaded into an RDF database for the Prez system to provide access to" ;
    schema:name "Manifest" ;
.

<https://prez.dev/ManifestResourceRoles/CatalogueData>
    schema:description "Data for the container, usually a Catalogue, including the identity of it and each item fo content" ;
    schema:name "Catalogue Data" ;
.

<https://prez.dev/ManifestResourceRoles/CompleteCatalogueAndResourceLabels>
    schema:description "All the labels - possibly including names, descriptions & seeAlso links - for the Catalogue and Resource objects" ;
    schema:name "Complete Catalogue and Resource Labels" ;
.

<https://prez.dev/ManifestResourceRoles/ResourceData>
    schema:description "Data for the content of the container" ;
    schema:name "Resource Data" ;
.

schema:DataCatalog
    schema:description "A collection of datasets." ;
    schema:name "DataCatalog" ;
.

schema:Organization
    schema:description "An organization such as a school, NGO, corporation, club, etc." ;
    schema:name "Organization" ;
.

schema:Person
    schema:description "A person (alive, dead, undead, or fictional)." ;
    schema:name "Person" ;
.

schema:citation
    schema:description "A citation or reference to another creative work, such as another publication, web page, scholarly article, etc." ;
    schema:name "citation" ;
.

schema:codeRepository
    schema:description "Link to the repository where the un-compiled, human readable code and related code is located (SVN, GitHub, CodePlex)." ;
    schema:name "codeRepository" ;
.

schema:contributor
    schema:description "A secondary contributor to the CreativeWork or Event." ;
    schema:name "contributor" ;
.

schema:creator
    schema:description "The creator/author of this CreativeWork. This is the same as the Author property for CreativeWork." ;
    schema:name "creator" ;
.

schema:dateCreated
    schema:description "The date on which the CreativeWork was created or the item was added to a DataFeed." ;
    schema:name "dateCreated" ;
.

schema:dateModified
    schema:description "The date on which the CreativeWork was most recently modified or when the item's entry was modified within a DataFeed." ;
    schema:name "dateModified" ;
.

schema:description
    schema:description "A description of the item." ;
    schema:name "description" ;
.

schema:email
    schema:description "Email address." ;
    schema:name "email" ;
.

schema:hasPart
    schema:description
        "Indicates a Resource that is part of this item" ,
        "Indicates an item or CreativeWork that is part of this item, or CreativeWork (in some sense)." ;
    schema:name
        "hasPart" ,
        "member" ;
.

schema:license
    schema:description "A license document that applies to this content, typically indicated by URL." ;
    schema:name "license" ;
.

schema:name
    schema:description "The name of the item" ;
    schema:name "name" ;
.

schema:publisher
    schema:description "The publisher of the creative work." ;
    schema:name "publisher" ;
.

schema:url
    schema:description "URL of the item." ;
    schema:name "url" ;
.

schema:version
    schema:description "The version of the CreativeWork embodied by a specified resource." ;
    schema:name "version" ;
.


schema:parentOrganization
    schema:description "The larger organization that this organization is a [[subOrganization]] of, if any." ;
    schema:name "parentOrganization" ;
.

<http://www.w3.org/2000/01/rdf-schema#isDefinedBy> schema:name "is defined by" .
<http://www.w3.org/ns/prov#agent> schema:name "agent" .
<http://www.w3.org/ns/prov#hadRole> schema:name "had role" .
<http://www.w3.org/ns/prov#qualifiedAttribution> schema:name "qualified attribution" .